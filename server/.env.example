# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/insightful-hr
MONGODB_TEST_URI=mongodb://localhost:27017/insightful-hr-test

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Email Configuration (Optional - for OTP/Password Reset)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=your_password
SENDER_EMAIL=noreply@insightful-hr.com

# CORS Configuration
FRONTEND_URLS=http://localhost:8082,http://localhost:8083,http://localhost:8084

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

